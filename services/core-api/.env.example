# Miori Core API configuration (copy to .env and adjust)

# --- App ---
APP_NAME=Miori Core
APP_VERSION=0.1.0
DEBUG=true

# --- Server ---
HOST=127.0.0.1
PORT=8000

# --- Database ---
DATABASE_URL=sqlite:///./miori.db

# --- CORS (comma-separated) ---
# Desktop (Tauri/Vite strictPort 1420) + remote dashboard (5174).
CORS_ORIGINS=http://localhost:1420,http://127.0.0.1:1420,http://localhost:5174,http://127.0.0.1:5174,http://localhost:5173,http://127.0.0.1:5173

# --- Feature flags ---
REMOTE_ENABLED=true
# Keep heavy/optional deps lazy so Miori stays usable on low-end machines.
LITE_MODE=true

# --- Paths ---
PROMPTS_DIR=../../packages/prompts
UPLOAD_DIR=./data/uploads

# --- Uploads ---
# Max upload size in bytes (default 25 MB).
MAX_UPLOAD_BYTES=26214400

# --- Providers ---
# Active provider on first boot: mock | openai | gemini. Persisted to the DB and
# adjustable at runtime via PUT /api/providers/active. Falls back to mock when
# the selected provider has no API key.
DEFAULT_PROVIDER=mock

# OpenAI / OpenAI-compatible (works for OpenAI, OpenRouter, local servers).
# Point OPENAI_BASE_URL at OpenRouter (https://openrouter.ai/api/v1) or a local
# server (http://localhost:11434/v1, etc.) to reuse the same provider.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Google Gemini (GEMINI_API_KEY preferred; GOOGLE_API_KEY accepted as alias).
GEMINI_API_KEY=
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Groq (OpenAI-compatible).
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Mistral (OpenAI-compatible).
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-small-latest

# SambaNova (OpenAI-compatible).
SAMBANOVA_API_KEY=
SAMBANOVA_MODEL=Meta-Llama-3.1-8B-Instruct

# OpenRouter (OpenAI-compatible).
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini

# Hugging Face Inference (huggingface_hub).
HUGGINGFACE_API_KEY=
HUGGINGFACE_MODEL=meta-llama/Llama-3.1-8B-Instruct

# Cohere (cohere SDK v2).
COHERE_API_KEY=
COHERE_MODEL=command-r

# Cloudflare Workers AI (needs both key + account id).
CLOUDFLARE_API_KEY=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_MODEL=@cf/meta/llama-3.1-8b-instruct
