# Miori Core API configuration (copy to .env and adjust)

# --- App ---
APP_NAME=Miori Core
APP_VERSION=0.1.0
DEBUG=true

# --- Server ---
HOST=127.0.0.1
PORT=8000

# --- Database ---
DATABASE_URL=sqlite:///./miori.db

# --- CORS (comma-separated) ---
CORS_ORIGINS=http://localhost:1420,http://localhost:3000

# --- Feature flags ---
REMOTE_ENABLED=true
# Keep heavy/optional deps lazy so Miori stays usable on low-end machines.
LITE_MODE=true

# --- Paths ---
PROMPTS_DIR=../../packages/prompts
UPLOAD_DIR=./data/uploads
